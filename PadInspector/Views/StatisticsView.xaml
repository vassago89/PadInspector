<UserControl x:Class="PadInspector.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="8" Padding="12,10"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
            Background="#08FFFFFF">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="검사 이력" FontWeight="SemiBold" FontSize="13"
                       Margin="2,0,0,10" Opacity="0.9"/>
            <ListView ItemsSource="{Binding Results}" FontSize="11" BorderThickness="0"
                      Background="Transparent">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="32" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="CAM" Width="48" DisplayMemberBinding="{Binding CameraName}"/>
                        <GridViewColumn Header="판정" Width="48">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsPass, Converter={StaticResource BoolToPassFail}}"
                                               Foreground="{Binding IsPass, Converter={StaticResource BoolToColor}}"
                                               FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="점수" Width="42" DisplayMemberBinding="{Binding Score}"/>
                        <GridViewColumn Header="시간" Width="62" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>
    </Border>
</UserControl>
