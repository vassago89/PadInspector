<Application x:Class="PadInspector.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PadInspector.Converters"
             xmlns:vm="clr-namespace:PadInspector.ViewModels"
             xmlns:views="clr-namespace:PadInspector.Views"
             ThemeMode="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Strings.ko.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:BoolToColorConverter x:Key="BoolToColor"/>
            <conv:BoolToPassFailConverter x:Key="BoolToPassFail"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>

            <!-- ViewModel -> View mapping -->
            <DataTemplate DataType="{x:Type vm:CameraViewModel}">
                <views:CameraView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RecipeViewModel}">
                <views:RecipeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
                <views:StatisticsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
