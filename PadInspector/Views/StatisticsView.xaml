<UserControl x:Class="PadInspector.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardPanel}">
        <DockPanel>
            <!-- Header -->
            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource S.InspectionHistory}"
                       Style="{StaticResource SectionTitle}" Margin="2,0,0,6"/>

            <!-- Filter + Export -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="2,0,0,10">
                <Button Content="{DynamicResource S.All}" Style="{StaticResource PillButton}" Margin="0,0,3,0"
                        Command="{Binding SetFilterCommand}" CommandParameter="All"/>
                <Button Style="{StaticResource PillButton}" Margin="0,0,3,0"
                        Foreground="{StaticResource SuccessBrush}"
                        Command="{Binding SetFilterCommand}" CommandParameter="Pass">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource S.Pass}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PillButton}" Margin="0,0,8,0"
                        Foreground="{StaticResource DangerBrush}"
                        Command="{Binding SetFilterCommand}" CommandParameter="Fail">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource DangerBrush}" Margin="0,0,5,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource S.Fail}"/>
                    </StackPanel>
                </Button>
                <Button Content="{DynamicResource S.ExportReport}" Style="{StaticResource PillButton}"
                        Command="{Binding ExportReportCommand}"/>
            </StackPanel>

            <ListView ItemsSource="{Binding FilteredResults}" FontSize="11" BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="34" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="CAM" Width="52" DisplayMemberBinding="{Binding CameraName}"/>
                        <GridViewColumn Width="52">
                            <GridViewColumn.Header>
                                <TextBlock Text="{DynamicResource S.Result}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsPass, Converter={StaticResource BoolToPassFail}}"
                                               Foreground="{Binding IsPass, Converter={StaticResource BoolToColor}}"
                                               FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="48">
                            <GridViewColumn.Header>
                                <TextBlock Text="{DynamicResource S.Score}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Score}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="68">
                            <GridViewColumn.Header>
                                <TextBlock Text="{DynamicResource S.Time}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                               Foreground="{StaticResource MutedBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>
    </Border>
</UserControl>
