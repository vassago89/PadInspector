<Window x:Class="PadInspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PadInspector.Views"
        Title="Pad Inspector"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Padding="16,8,16,8" Background="#0AFFFFFF"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- App Title + Run Controls -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="PAD INSPECTOR" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               Opacity="0.5" Margin="0,0,24,0"/>
                    <Button Padding="20,7" Margin="0,0,4,0" FontSize="13" FontWeight="SemiBold"
                            Background="#0F7B3F" Foreground="White" HorizontalContentAlignment="Center"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal">
                            <Polygon Points="0,0 8,5 0,10" Fill="White" Margin="0,1,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S.Start}"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="20,7" Margin="0,0,4,0" FontSize="13" FontWeight="SemiBold"
                            Background="#C42B1C" Foreground="White" HorizontalContentAlignment="Center"
                            Command="{Binding StopCommand}" IsEnabled="{Binding IsRunning}">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="9" Height="9" Fill="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S.Stop}"/>
                        </StackPanel>
                    </Button>
                    <Button Content="{DynamicResource S.ManualTrigger}" Padding="14,7" FontSize="12"
                            Command="{Binding ManualTriggerCommand}" HorizontalContentAlignment="Center"
                            IsEnabled="{Binding IsRunning}"/>
                    <Rectangle Width="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="20,4"/>
                    <Border Width="10" Height="10" CornerRadius="5" Margin="0,0,8,0" VerticalAlignment="Center"
                            Background="{Binding IsRunning, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Opacity="0.5"/>
                </StackPanel>

                <!-- Stats -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Total -->
                    <Border Padding="14,4" Margin="4,0" CornerRadius="6" Background="#08FFFFFF">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="TOTAL" FontSize="9" HorizontalAlignment="Center"
                                       Opacity="0.35" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Statistics.TotalCount}" FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Pass -->
                    <Border Padding="14,4" Margin="4,0" CornerRadius="6" Background="#0A4CAF50">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="PASS" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="#4CAF50" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Statistics.PassCount}" FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="#4CAF50" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Fail -->
                    <Border Padding="14,4" Margin="4,0" CornerRadius="6" Background="#0AF44336">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="FAIL" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="#F44336" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Statistics.FailCount}" FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="#F44336" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Yield -->
                    <Border Padding="14,4" Margin="4,0,12,0" CornerRadius="6" Background="#0A2196F3">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="YIELD" FontSize="9" HorizontalAlignment="Center"
                                       Foreground="#64B5F6" FontWeight="SemiBold"/>
                            <TextBlock FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="#64B5F6" Margin="0,-2,0,0">
                                <Run Text="{Binding Statistics.PassRate, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Button Content="{DynamicResource S.Reset}" Padding="10,6" VerticalAlignment="Center"
                            FontSize="11" Command="{Binding ResetCountCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Alarm Banner -->
        <Border Grid.Row="1" Panel.ZIndex="99"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,10,0,0" Padding="28,12" CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8C42B1C"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ALARM" FontSize="16" Foreground="White" FontWeight="Bold"
                           Margin="0,0,14,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AlarmMessage}" Foreground="#DDFFFFFF"
                           FontSize="14" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <Button Content="{DynamicResource S.AlarmClear}" Command="{Binding ClearAlarmCommand}" Padding="16,5"/>
            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Margin="8,8,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Settings -->
            <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,4,0"
                    Background="#08FFFFFF">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-2,0,-2,0">
                    <StackPanel>
                        <!-- Camera -->
                        <TextBlock Text="{DynamicResource S.Camera}" FontWeight="SemiBold" FontSize="13" Opacity="0.9" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{DynamicResource S.Connect}" Padding="8,6" HorizontalContentAlignment="Center"
                                    Command="{Binding ConnectCamerasCommand}"/>
                            <Button Grid.Column="2" Content="{DynamicResource S.Disconnect}" Padding="8,6" HorizontalContentAlignment="Center"
                                    Command="{Binding DisconnectCamerasCommand}"/>
                        </Grid>
                        <Grid Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                        Background="{Binding Camera1.IsConnected, Converter={StaticResource BoolToColor}}"/>
                                <TextBlock Text="CAM1" FontSize="11" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                        Background="{Binding Camera2.IsConnected, Converter={StaticResource BoolToColor}}"/>
                                <TextBlock Text="CAM2" FontSize="11" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,14,0,14"/>

                        <!-- Recipe View -->
                        <ContentControl Content="{Binding Recipe}"/>

                        <Separator Margin="0,14,0,14"/>

                        <!-- Auto Trigger -->
                        <Expander Header="{DynamicResource S.AutoTrigger}">
                            <StackPanel Margin="0,10,0,0">
                                <CheckBox Content="{DynamicResource S.UseAutoTrigger}" Margin="0,0,0,10"
                                          IsChecked="{Binding AutoTrigger}"/>
                                <TextBlock Text="{DynamicResource S.IntervalMs}" FontSize="10" Opacity="0.35" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding Recipe.TriggerInterval, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Expander>

                        <Separator Margin="0,14,0,14"/>

                        <!-- Settings -->
                        <Expander Header="Settings">
                            <ContentControl Content="{Binding Settings}" Margin="0,8,0,0"/>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- CENTER -->
            <Grid Grid.Column="1" Margin="4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150" MinHeight="80"/>
                </Grid.RowDefinitions>

                <!-- Cameras -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ContentControl Grid.Column="0" Content="{Binding Camera1}"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>
                    <ContentControl Grid.Column="2" Content="{Binding Camera2}"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                </Grid>

                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                              ResizeDirection="Rows" Background="Transparent"/>

                <!-- Yield Chart -->
                <views:YieldChart Grid.Row="2" Data="{Binding Statistics.YieldTrend}" Margin="0,2,0,2"/>

                <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch"
                              ResizeDirection="Rows" Background="Transparent"/>

                <!-- Log -->
                <Border Grid.Row="4" CornerRadius="8"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                        Padding="12,8,12,6" Background="#08FFFFFF">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="{DynamicResource S.Log}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Opacity="0.7"/>
                            <Button DockPanel.Dock="Right" Content="{DynamicResource S.Clear}" Padding="12,3" FontSize="11"
                                    HorizontalAlignment="Right" Command="{Binding ClearLogCommand}"/>
                        </DockPanel>
                        <ListBox x:Name="LogListBox" ItemsSource="{Binding LogService.Messages}"
                                 FontFamily="Cascadia Mono,Consolas,Courier New" FontSize="11"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Opacity" Value="0.75"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- RIGHT: Statistics -->
            <ContentControl Grid.Column="2" Content="{Binding Statistics}" Margin="4,0,0,0"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Padding="14,5" Background="#06FFFFFF"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Pad Inspector v1.0" FontSize="10" Opacity="0.25"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="10" Opacity="0.35" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="Total:"/><Run Text="{Binding Statistics.TotalCount, Mode=OneWay}"/>
                        <Run Text="  Pass:"/><Run Text="{Binding Statistics.PassCount, Mode=OneWay}"/>
                        <Run Text="  Fail:"/><Run Text="{Binding Statistics.FailCount, Mode=OneWay}"/>
                        <Run Text="  Yield:"/><Run Text="{Binding Statistics.PassRate, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                    <Button Content="Theme" Padding="6,2" FontSize="10" Margin="0,0,8,0"
                            Click="OnToggleThemeClick"/>
                    <Button Content="KO" Padding="6,2" FontSize="10" Margin="0,0,2,0"
                            Click="OnKoreanClick"/>
                    <Button Content="EN" Padding="6,2" FontSize="10"
                            Click="OnEnglishClick"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
