<UserControl x:Class="PadInspector.Views.YieldChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardPanel}" Padding="8,6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{DynamicResource S.YieldTrend}"
                       Style="{StaticResource SectionTitle}" Margin="4,0,0,2"/>
            <Canvas x:Name="ChartCanvas" Grid.Row="1" SizeChanged="OnSizeChanged"/>
        </Grid>
    </Border>
</UserControl>
