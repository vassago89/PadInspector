<Application x:Class="PadInspector.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PadInspector.Converters"
             xmlns:vm="clr-namespace:PadInspector.ViewModels"
             xmlns:views="clr-namespace:PadInspector.Views"
             ThemeMode="Dark">
    <Application.Resources>
        <!-- Converters -->
        <conv:BoolToColorConverter x:Key="BoolToColor"/>
        <conv:BoolToPassFailConverter x:Key="BoolToPassFail"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>

        <!-- ViewModel -> View mapping -->
        <DataTemplate DataType="{x:Type vm:CameraViewModel}">
            <views:CameraView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecipeViewModel}">
            <views:RecipeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView/>
        </DataTemplate>
    </Application.Resources>
</Application>
