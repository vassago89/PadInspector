<Window x:Class="PadInspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PadInspector.ViewModels"
        xmlns:conv="clr-namespace:PadInspector.Converters"
        Title="Pad Inspector"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- DataContext is set via DI in code-behind -->
    <Window.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColor"/>
        <conv:BoolToPassFailConverter x:Key="BoolToPassFail"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Title bar button style -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#181825">
            <DockPanel LastChildFill="True">
                <!-- Window buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;" Click="OnMinimize"/>
                    <Button x:Name="BtnMaxRestore" Style="{StaticResource TitleBarButton}" Content="&#xE922;" Click="OnMaximizeRestore"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" Click="OnClose"/>
                </StackPanel>

                <!-- Status indicator + title (left) -->
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock Text="Pad Inspector" Foreground="#CDD6F4" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" | " Foreground="#585B70" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#6C7086" FontSize="11"
                               VerticalAlignment="Center" MaxWidth="600" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="8,4,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Left Panel: Controls -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <!-- Recipe -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="레시피 (모델)" Style="{StaticResource HeaderText}"/>
                            <ComboBox ItemsSource="{Binding RecipeNames}"
                                      SelectedItem="{Binding SelectedRecipeName}"
                                      Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                      Height="28" Margin="0,0,0,6"/>
                            <TextBlock Text="이름" Style="{StaticResource ValueText}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding RecipeName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,4"/>
                            <TextBlock Text="설명" Style="{StaticResource ValueText}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding RecipeDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,6"/>

                            <TextBlock Text="Threshold" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipeThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,3"/>
                            <TextBlock Text="Min Area Ratio" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipeMinArea, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,3"/>
                            <TextBlock Text="Max Area Ratio" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipeMaxArea, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,3"/>
                            <TextBlock Text="Pass Score (%)" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipePassScore, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,3"/>
                            <TextBlock Text="Exposure (us)" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipeExposure, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,3"/>
                            <TextBlock Text="Gain (dB)" Style="{StaticResource ValueText}" Margin="0,2,0,2"/>
                            <TextBox Text="{Binding RecipeGain, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2" Margin="0,0,0,6"/>

                            <Button Content="저장" Style="{StaticResource ActionButton}"
                                    Command="{Binding SaveRecipeCommand}"
                                    Background="#89B4FA" Foreground="#1E1E2E"/>
                            <Button Content="다른이름 저장" Style="{StaticResource ActionButton}"
                                    Command="{Binding SaveRecipeAsCommand}"/>
                            <Button Content="삭제" Style="{StaticResource ActionButton}"
                                    Command="{Binding DeleteRecipeCommand}"
                                    Background="#F38BA8" Foreground="#1E1E2E"/>
                        </StackPanel>
                    </Border>

                    <!-- Camera -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="카메라" Style="{StaticResource HeaderText}"/>
                            <Button Content="카메라 연결" Style="{StaticResource ActionButton}"
                                    Command="{Binding ConnectCameraCommand}"
                                    IsEnabled="{Binding IsCameraConnected, Converter={StaticResource InverseBool}}"/>
                            <Button Content="카메라 해제" Style="{StaticResource ActionButton}"
                                    Command="{Binding DisconnectCameraCommand}"
                                    IsEnabled="{Binding IsCameraConnected}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                                         Fill="{Binding IsCameraConnected, Converter={StaticResource BoolToColor}}"/>
                                <TextBlock Style="{StaticResource ValueText}"
                                           Text="{Binding IsCameraConnected, Converter={StaticResource BoolToPassFail}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Run Control -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="실행 제어" Style="{StaticResource HeaderText}"/>
                            <Button Content="시작" Style="{StaticResource ActionButton}"
                                    Command="{Binding StartCommand}"
                                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}"
                                    Background="#40A02B" Foreground="White"/>
                            <Button Content="정지" Style="{StaticResource ActionButton}"
                                    Command="{Binding StopCommand}"
                                    IsEnabled="{Binding IsRunning}"
                                    Background="#D20F39" Foreground="White"/>
                            <Button Content="수동 트리거" Style="{StaticResource ActionButton}"
                                    Command="{Binding ManualTriggerCommand}"
                                    IsEnabled="{Binding IsRunning}"
                                    Background="#1E66F5" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Auto Trigger -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="자동 트리거" Style="{StaticResource HeaderText}"/>
                            <CheckBox Content="자동 트리거" Foreground="#BAC2DE" Margin="0,0,0,6"
                                      IsChecked="{Binding AutoTrigger}"/>
                            <TextBlock Text="주기 (ms)" Style="{StaticResource ValueText}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding TriggerInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                     Height="26" Padding="4,2"/>
                        </StackPanel>
                    </Border>

                    <!-- Count -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="검사 결과 집계" Style="{StaticResource HeaderText}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="전체" Style="{StaticResource ValueText}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalCount}" Style="{StaticResource ValueText}" FontWeight="Bold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="양품" Style="{StaticResource ValueText}" Foreground="LimeGreen"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PassCount}" Style="{StaticResource ValueText}" Foreground="LimeGreen" FontWeight="Bold"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="불량" Style="{StaticResource ValueText}" Foreground="Red"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FailCount}" Style="{StaticResource ValueText}" Foreground="Red" FontWeight="Bold"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="수율" Style="{StaticResource ValueText}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueText}" FontWeight="Bold">
                                    <Run Text="{Binding PassRate, Mode=OneWay}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                            <Button Content="카운트 초기화" Style="{StaticResource ActionButton}"
                                    Command="{Binding ResetCountCommand}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Center: Image + Log -->
            <Grid Grid.Column="1" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Image View -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,0">
                    <Grid>
                        <Image Source="{Binding CurrentImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <TextBlock Text="카메라 이미지 없음" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#585B70" FontSize="18"
                                   Visibility="{Binding CurrentImage, TargetNullValue=Visible, FallbackValue=Collapsed}"/>
                        <!-- Last Result Overlay -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="12" Padding="12,6" CornerRadius="6"
                                Background="#CC000000"
                                Visibility="{Binding LastResult, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                            <TextBlock FontSize="24" FontWeight="Bold"
                                       Text="{Binding LastResult.IsPass, Converter={StaticResource BoolToPassFail}}"
                                       Foreground="{Binding LastResult.IsPass, Converter={StaticResource BoolToColor}}"/>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="#45475A" ResizeDirection="Rows"/>

                <!-- Log Panel -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0" Margin="0,4,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="12,8,12,4">
                            <TextBlock Text="로그" Style="{StaticResource HeaderText}" DockPanel.Dock="Left" Margin="0"/>
                            <Button Content="지우기" Style="{StaticResource ActionButton}"
                                    Command="{Binding ClearLogCommand}"
                                    DockPanel.Dock="Right" Width="60" Height="22" FontSize="11" Margin="0"/>
                        </DockPanel>
                        <ListBox x:Name="LogListBox" ItemsSource="{Binding LogMessages}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#A6ADC8" FontFamily="Consolas" FontSize="11"
                                 Margin="8,0,8,8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2,1"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter Margin="0,1"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right Panel: Results -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="검사 이력" Style="{StaticResource HeaderText}" Margin="12,12,12,6"/>
                    <ListView ItemsSource="{Binding Results}" Background="Transparent" BorderThickness="0"
                              Foreground="#BAC2DE" FontSize="11">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="35" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="판정" Width="45">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsPass, Converter={StaticResource BoolToPassFail}}"
                                                       Foreground="{Binding IsPass, Converter={StaticResource BoolToColor}}"
                                                       FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="점수" Width="45" DisplayMemberBinding="{Binding Score}"/>
                                <GridViewColumn Header="시간" Width="65" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                <GridViewColumn Header="설명" Width="90" DisplayMemberBinding="{Binding Description}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#181825" CornerRadius="4" Padding="10,4" Margin="0,4,0,0">
                <DockPanel>
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#A6ADC8" FontSize="11" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
