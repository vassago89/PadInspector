<UserControl x:Class="PadInspector.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Image Save -->
        <TextBlock Text="{DynamicResource S.ImageSave}" Style="{StaticResource SectionTitle}"/>
        <CheckBox Content="{DynamicResource S.Enabled}" IsChecked="{Binding ImageSaveEnabled}" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="{DynamicResource S.SaveOK}" IsChecked="{Binding SaveOk}"/>
            <CheckBox Grid.Column="2" Content="{DynamicResource S.SaveNG}" IsChecked="{Binding SaveNg}"/>
        </Grid>
        <TextBlock Text="{DynamicResource S.Path}" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding ImageSavePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource S.Format}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource S.MaxDays}" Style="{StaticResource FieldLabel}"/>
            <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding ImageFormat, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding MaxDaysToKeep, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Separator Margin="0,10,0,10" Opacity="0.3"/>

        <!-- Alarm -->
        <TextBlock Text="{DynamicResource S.Alarm}" Style="{StaticResource SectionTitle}"/>
        <CheckBox Content="{DynamicResource S.Enabled}" IsChecked="{Binding AlarmEnabled}" Margin="0,0,0,4"/>
        <TextBlock Text="{DynamicResource S.ConsecutiveNgThreshold}" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding ConsecutiveNgThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

        <Separator Margin="0,10,0,10" Opacity="0.3"/>

        <!-- Log -->
        <TextBlock Text="{DynamicResource S.LogSettings}" Style="{StaticResource SectionTitle}"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="{DynamicResource S.FileLog}" IsChecked="{Binding EnableFileLog}"/>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{DynamicResource S.MaxLines}" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding MaxLogLines, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Separator Margin="0,10,0,10" Opacity="0.3"/>

        <!-- CSV Log -->
        <TextBlock Text="{DynamicResource S.CsvLog}" Style="{StaticResource SectionTitle}"/>
        <CheckBox Content="{DynamicResource S.Enabled}" IsChecked="{Binding CsvLogEnabled}" Margin="0,0,0,4"/>
        <TextBlock Text="{DynamicResource S.Path}" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding CsvLogPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

        <!-- Save Button -->
        <Button Content="{DynamicResource S.Save}" Command="{Binding SaveSettingsCommand}"
                Padding="8,6" HorizontalContentAlignment="Center" Margin="0,8,0,0"/>
        <TextBlock Text="{DynamicResource S.RestartRequired}" FontSize="9" Foreground="{StaticResource MutedBrush}"
                   Margin="0,4,0,0" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
