<UserControl x:Class="PadInspector.Views.CameraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PadInspector.Views">
    <Border CornerRadius="8"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
            Background="#08FFFFFF">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="#0CFFFFFF">
                <DockPanel Margin="14,0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12" Height="12" CornerRadius="6" Margin="0,0,10,0"
                                Background="{Binding IsConnected, Converter={StaticResource BoolToColor}}"/>
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontSize="11" Opacity="0.35">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text" Value="Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Image Area -->
            <views:ZoomPanImage Grid.Row="1" Source="{Binding Image}"/>

            <!-- Watermark -->
            <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="48" Opacity="0.04"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="Bold" IsHitTestVisible="False"
                       Visibility="{Binding Image, TargetNullValue=Visible, FallbackValue=Collapsed}"/>

            <!-- PASS/FAIL overlay -->
            <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,20" Padding="32,10" CornerRadius="10"
                    IsHitTestVisible="False"
                    Visibility="{Binding LastResult, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                <Border.Background>
                    <SolidColorBrush Color="Black" Opacity="0.75"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="32" FontWeight="Bold"
                               Text="{Binding LastResult.IsPass, Converter={StaticResource BoolToPassFail}}"
                               Foreground="{Binding LastResult.IsPass, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock FontSize="18" Foreground="#88FFFFFF" VerticalAlignment="Bottom" Margin="14,0,0,3">
                        <Run Text="{Binding LastResult.Score, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
