<UserControl x:Class="PadInspector.Views.CameraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PadInspector.Views">
    <Border Style="{StaticResource CardPanel}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="{StaticResource ElevatedBg}">
                <DockPanel Margin="14,0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12" Height="12" CornerRadius="6" Margin="0,0,10,0"
                                Background="{Binding IsConnected, Converter={StaticResource BoolToColor}}">
                            <!-- Pulse animation when connected -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="CamPulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.4" Duration="0:0:1"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="CamPulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                            CornerRadius="8" Padding="8,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource DangerBg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SuccessBg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="OFFLINE"/>
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="LIVE"/>
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Image Area -->
            <views:ZoomPanImage Grid.Row="1" Source="{Binding Image}"/>

            <!-- Watermark -->
            <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="48" Opacity="0.04"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="Bold" IsHitTestVisible="False"
                       Visibility="{Binding Image, Converter={StaticResource NullToCollapsed}}"/>

            <!-- PASS/FAIL overlay -->
            <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,20" Padding="32,10" CornerRadius="12"
                    IsHitTestVisible="False"
                    Visibility="{Binding LastResult, Converter={StaticResource NullToVisibility}}">
                <Border.Background>
                    <SolidColorBrush Color="Black" Opacity="0.8"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="32" FontWeight="Bold"
                               Text="{Binding LastResult.IsPass, Converter={StaticResource BoolToPassFail}}"
                               Foreground="{Binding LastResult.IsPass, Converter={StaticResource BoolToColor}}"/>
                    <TextBlock FontSize="18" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Bottom" Margin="14,0,0,3">
                        <Run Text="{Binding LastResult.Score, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Bottom" Margin="10,0,0,4">
                        <Run Text="{Binding LastResult.PadCount, Mode=OneWay}"/><Run Text=" pads"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
